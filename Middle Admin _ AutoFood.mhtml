@keyframes fade-in-up {=20
  0% { opacity: 0; transform: translateY(16px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes fade-in {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes scale-in {=20
  0% { opacity: 0; transform: scale(0.95); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes slide-in-right {=20
  0% { opacity: 0; transform: translate(24px); }
  100% { opacity: 1; transform: translate(0px); }
}

@keyframes slide-in-left {=20
  0% { opacity: 0; transform: translate(-24px); }
  100% { opacity: 1; transform: translate(0px); }
}

@keyframes float {=20
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  25% { transform: translateY(-10px) rotate(0.5deg); }
  75% { transform: translateY(5px) rotate(-0.5deg); }
}

@keyframes pulse-glow {=20
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.7; }
}

@keyframes shimmer {=20
  0% { background-position: -200% 0px; }
  100% { background-position: 200% 0px; }
}

@keyframes gradient-shift {=20
  0% { background-position: 0px center; }
  50% { background-position: 100% center; }
  100% { background-position: 0px center; }
}

@keyframes border-glow {=20
  0%, 100% { border-color: rgba(255, 255, 255, 0.06); }
  50% { border-color: rgba(255, 255, 255, 0.14); }
}

@keyframes rotate-slow {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}

@keyframes mesh-move {=20
  0% { transform: translate(0px) scale(1); }
  33% { transform: translate(30px, -30px) scale(1.1); }
  66% { transform: translate(-20px, 20px) scale(0.95); }
  100% { transform: translate(0px) scale(1); }
}

@keyframes counter-up {=20
  0% { opacity: 0; filter: blur(4px); transform: translateY(10px) scale(0.9=
); }
  100% { opacity: 1; filter: blur(); transform: translateY(0px) scale(1); }
}

@keyframes aurora {=20
  0% { opacity: 0.5; background-position: 0px center; }
  25% { opacity: 0.7; background-position: 50% 0px; }
  50% { opacity: 0.5; background-position: 100% center; }
  75% { opacity: 0.7; background-position: 50% 100%; }
  100% { opacity: 0.5; background-position: 0px center; }
}

@keyframes ripple {=20
  0% { opacity: 0.5; transform: scale(0); }
  100% { opacity: 0; transform: scale(4); }
}

@keyframes slide-up-fade {=20
  0% { opacity: 0; transform: translateY(20px) scale(0.98); }
  100% { opacity: 1; transform: translateY(0px) scale(1); }
}

@keyframes glow-line {=20
  0%, 100% { opacity: 0; transform: translate(-100%); }
  50% { opacity: 1; }
  100% { transform: translate(100%); }
}

@keyframes morph {=20
  0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  25% { border-radius: 30% 60% 70% 40% / 50% 60% 30%; }
  50% { border-radius: 50% 60% 30% / 30% 50% 70%; }
  75% { border-radius: 40% 60% 50% 40% / 60% 40% 60% 50%; }
}

@keyframes number-count {=20
  0% { opacity: 0; filter: blur(8px); transform: scale(0.5); }
  100% { opacity: 1; filter: blur(); transform: scale(1); }
}

@keyframes sparkle {=20
  0%, 100% { opacity: 0; transform: scale(0) rotate(0deg); }
  50% { opacity: 1; transform: scale(1) rotate(180deg); }
}

@keyframes dot-pulse {=20
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.5); }
}

