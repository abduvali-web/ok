{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-tambo-api-catalog.mjs && node scripts/generate-tambo-ui-catalog.mjs && prisma generate && node scripts/vercel-db-push.mjs && next build",
    "build:unsafe": "node scripts/generate-tambo-api-catalog.mjs && node scripts/generate-tambo-ui-catalog.mjs && prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/.eslintcache --ext .js,.jsx,.ts,.tsx src tests",
    "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/.eslintcache --ext .js,.jsx,.ts,.tsx src tests --fix",
    "typecheck": "node scripts/prisma-generate.mjs && node scripts/clean-next-types.mjs && tsc -p tsconfig.json --noEmit",
    "quality:report": "node scripts/quality-report.mjs",
    "quality:report:json": "node scripts/quality-report.mjs --json",
    "db:push": "prisma db push",
    "db:push:accept-data-loss": "prisma db push --accept-data-loss",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "test": "playwright test --pass-with-no-tests",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "push": "git push",
    "push:unsafe": "prisma db push --accept-data-loss && git push",
    "seed": "tsx prisma/seed.ts",
    "tambo:api-catalog": "node scripts/generate-tambo-api-catalog.mjs",
    "tambo:ui-catalog": "node scripts/generate-tambo-ui-catalog.mjs",
    "db:translate-website-content": "tsx scripts/translate-website-content.ts"
  },
